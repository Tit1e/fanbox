{
  "name": "codexbox",
  "version": "2.6.10",
  "description": "CodexBox — the local desktop cockpit for Codex. Run Codex, watch every file and line it changes, and take over anytime.",
  "bin": {
    "codexbox": "server.js"
  },
  "main": "electron/main.js",
  "scripts": {
    "test": "node --test tests/server/*.test.js tests/frontend/*.test.mjs tests/electron/*.test.js",
    "check": "npm run build:svelte && node --check server.js && find server electron build -name '*.js' -exec node --check {} \\; && node --input-type=module --check < public/app.js && find public/modules -name '*.js' -exec sh -c 'node --input-type=module --check < \"$1\"' _ {} \\; && node --check public/i18n-dict.js && npm test",
    "postinstall": "node build/prepare-node-pty.js",
    "start": "node server.js --dev",
    "app": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "rebuild:pty": "cd node_modules/node-pty && node-gyp rebuild --target=$(node -p \"require('electron/package.json').version\") --dist-url=https://www.electronjs.org/headers --arch=$PTY_ARCH",
    "build:milkdown": "esbuild src-vendor/milkdown-entry.js --bundle --format=iife --minify --outfile=public/vendor/milkdown/milkdown.js --loader:.svg=dataurl --loader:.woff=file --loader:.woff2=file --loader:.ttf=file --loader:.eot=file --asset-names=[name]",
    "build:hljs": "esbuild src-vendor/hljs-entry.js --bundle --format=iife --minify --outfile=public/vendor/hljs/highlight.js && cp node_modules/marked/marked.min.js public/vendor/marked/marked.min.js && cp node_modules/highlight.js/styles/github-dark.min.css node_modules/highlight.js/styles/github.min.css public/vendor/hljs/styles/",
    "build:svelte": "node build/svelte-ui.mjs",
    "dist": "npm run build:svelte && electron-builder --mac --arm64",
    "dist:x64": "npm run build:svelte && PTY_ARCH=x64 npm run rebuild:pty && electron-builder --mac --x64 && PTY_ARCH=arm64 npm run rebuild:pty"
  },
  "build": {
    "appId": "com.huashu.codexbox",
    "productName": "CodexBox",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "afterPack": "build/after-pack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": "Apple Development: Haoliang Chen (GVN8YV4PYF)",
      "notarize": false,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg"
        }
      ]
    },
    "dmg": {
      "title": "CodexBox",
      "writeUpdateInfo": false
    }
  },
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@milkdown/crepe": "^7.21.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "esbuild-svelte": "^0.9.5",
    "happy-dom": "^20.10.6",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "monaco-editor": "^0.52.2",
    "node-gyp": "^12.4.0",
    "svelte": "^5.56.4"
  },
  "license": "MIT"
}
